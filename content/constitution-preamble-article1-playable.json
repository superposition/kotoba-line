  "documents": [
    {
      "id": "jp-constitution",
      "title": "日本国憲法",
      "source_path": "content/documents/japan-constitution-preamble-article1.json",
      "source_date": "1946-11-03",
      "sections": [
        {
          "id": "preamble-1",
          "heading": "前文 第一段",
          "markdown": "日本国民は、正当に選挙された国会における代表者を通じて行動し、われらとわれらの子孫のために、諸国民との協和による成果と、わが国全土にわたつて自由のもたらす恵沢を確保し、政府の行為によつて再び戦争の惨禍が起ることのないやうにすることを決意し、ここに主権が国民に存することを宣言し、この憲法を確定する。"
        },
        {
          "id": "article-1",
          "heading": "第一章 天皇 第一条",
          "markdown": "第一条 天皇は、日本国の象徴であり日本国民統合の象徴であつて、この地位は、主権の存する日本国民の総意に基く。"
        }
      ]
    }
  ],
